# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# PWA / Service Worker (auto-generated)
public/sw.js
public/workbox-*.js
public/worker-*.js
public/sw-*.js
public/precache-manifest*.js
public/fallback-*.js

# next-pwa generated files
public/_next/static/workbox-*.js
public/_next/static/sw.js
public/_next/static/chunks/webpack-*.js

# Workbox
**/workbox-*.js
**/sw.js
**/precache-manifest*.js